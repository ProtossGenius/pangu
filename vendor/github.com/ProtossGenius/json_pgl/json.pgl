package json_pgl;

// JSON value types
type JsonType enum {
    JSON_NULL
    JSON_BOOL
    JSON_NUMBER
    JSON_STRING
    JSON_ARRAY
    JSON_OBJECT
}

// Parse a JSON number starting at position pos in string s.
// Returns the parsed integer value.
func parse_json_number(s string, pos int, end int) int {
    result := 0;
    neg := 0;
    i := pos;
    ch := str_char_at(s, i);
    if (ch == 45) {
        neg = 1;
        i = i + 1;
    }
    while (i < end) {
        ch = str_char_at(s, i);
        if (ch < 48 || ch > 57) {
            break;
        }
        result = result * 10 + (ch - 48);
        i = i + 1;
    }
    if (neg == 1) {
        result = 0 - result;
    }
    return result;
}

// Skip whitespace in string s starting at position pos.
// Returns new position after whitespace.
func skip_whitespace(s string, pos int) int {
    len := str_len(s);
    i := pos;
    while (i < len) {
        ch := str_char_at(s, i);
        if (ch != 32 && ch != 9 && ch != 10 && ch != 13) {
            return i;
        }
        i = i + 1;
    }
    return i;
}

// Parse a JSON string starting at position pos (after opening quote).
// Returns the string content (without quotes).
func parse_json_string_value(s string, pos int) string {
    len := str_len(s);
    i := pos + 1;
    result := "";
    while (i < len) {
        ch := str_char_at(s, i);
        if (ch == 34) {
            return result;
        }
        if (ch == 92) {
            i = i + 1;
            if (i < len) {
                esc := str_char_at(s, i);
                if (esc == 110) {
                    result = str_concat(result, "\n");
                } else if (esc == 116) {
                    result = str_concat(result, "\t");
                } else if (esc == 34) {
                    result = str_concat(result, "\"");
                } else if (esc == 92) {
                    result = str_concat(result, "\\");
                } else {
                    result = str_concat(result, char_to_str(esc));
                }
            }
        } else {
            result = str_concat(result, char_to_str(ch));
        }
        i = i + 1;
    }
    return result;
}

// Find the end position of a JSON string starting at pos (opening quote).
func find_string_end(s string, pos int) int {
    len := str_len(s);
    i := pos + 1;
    while (i < len) {
        ch := str_char_at(s, i);
        if (ch == 34) {
            return i + 1;
        }
        if (ch == 92) {
            i = i + 1;
        }
        i = i + 1;
    }
    return i;
}

// Find the end of a JSON number starting at pos.
func find_number_end(s string, pos int) int {
    len := str_len(s);
    i := pos;
    ch := str_char_at(s, i);
    if (ch == 45) {
        i = i + 1;
    }
    while (i < len) {
        ch = str_char_at(s, i);
        if (ch < 48 || ch > 57) {
            return i;
        }
        i = i + 1;
    }
    return i;
}

// Detect the JSON type at position pos.
// Returns the JsonType enum value.
func detect_json_type(s string, pos int) int {
    ch := str_char_at(s, pos);
    if (ch == 34) {
        return 3;
    }
    if (ch == 116 || ch == 102) {
        return 1;
    }
    if (ch == 110) {
        return 0;
    }
    if (ch == 91) {
        return 4;
    }
    if (ch == 123) {
        return 5;
    }
    return 2;
}

// Parse a JSON boolean. Returns 1 for true, 0 for false.
func parse_json_bool(s string, pos int) int {
    ch := str_char_at(s, pos);
    if (ch == 116) {
        return 1;
    }
    return 0;
}

// Find end of a JSON value (any type) starting at pos.
func find_value_end(s string, pos int) int {
    ch := str_char_at(s, pos);
    if (ch == 34) {
        return find_string_end(s, pos);
    }
    if (ch == 116) {
        return pos + 4;
    }
    if (ch == 102) {
        return pos + 5;
    }
    if (ch == 110) {
        return pos + 4;
    }
    if (ch == 91) {
        return find_array_end(s, pos);
    }
    if (ch == 123) {
        return find_object_end(s, pos);
    }
    return find_number_end(s, pos);
}

// Find end of a JSON array starting at pos (opening bracket).
func find_array_end(s string, pos int) int {
    len := str_len(s);
    i := pos + 1;
    i = skip_whitespace(s, i);
    if (i < len) {
        ch := str_char_at(s, i);
        if (ch == 93) {
            return i + 1;
        }
    }
    while (i < len) {
        i = skip_whitespace(s, i);
        i = find_value_end(s, i);
        i = skip_whitespace(s, i);
        if (i < len) {
            ch := str_char_at(s, i);
            if (ch == 93) {
                return i + 1;
            }
            if (ch == 44) {
                i = i + 1;
            }
        }
    }
    return i;
}

// Find end of a JSON object starting at pos (opening brace).
func find_object_end(s string, pos int) int {
    len := str_len(s);
    i := pos + 1;
    i = skip_whitespace(s, i);
    if (i < len) {
        ch := str_char_at(s, i);
        if (ch == 125) {
            return i + 1;
        }
    }
    while (i < len) {
        i = skip_whitespace(s, i);
        i = find_string_end(s, i);
        i = skip_whitespace(s, i);
        if (i < len) {
            ch := str_char_at(s, i);
            if (ch == 58) {
                i = i + 1;
            }
        }
        i = skip_whitespace(s, i);
        i = find_value_end(s, i);
        i = skip_whitespace(s, i);
        if (i < len) {
            ch := str_char_at(s, i);
            if (ch == 125) {
                return i + 1;
            }
            if (ch == 44) {
                i = i + 1;
            }
        }
    }
    return i;
}

// Get a string value from a JSON object by key.
// Returns the string value or empty string if not found.
func json_get_string(json string, key string) string {
    len := str_len(json);
    pos := skip_whitespace(json, 0);
    if (pos >= len) {
        return "";
    }
    ch := str_char_at(json, pos);
    if (ch != 123) {
        return "";
    }
    pos = pos + 1;
    while (pos < len) {
        pos = skip_whitespace(json, pos);
        if (pos >= len) {
            return "";
        }
        ch = str_char_at(json, pos);
        if (ch == 125) {
            return "";
        }
        k := parse_json_string_value(json, pos);
        pos = find_string_end(json, pos);
        pos = skip_whitespace(json, pos);
        if (pos >= len) {
            return "";
        }
        ch = str_char_at(json, pos);
        if (ch == 58) {
            pos = pos + 1;
        }
        pos = skip_whitespace(json, pos);
        if (str_eq(k, key) == 1) {
            ch = str_char_at(json, pos);
            if (ch == 34) {
                return parse_json_string_value(json, pos);
            }
            return "";
        }
        pos = find_value_end(json, pos);
        pos = skip_whitespace(json, pos);
        if (pos < len) {
            ch = str_char_at(json, pos);
            if (ch == 44) {
                pos = pos + 1;
            }
        }
    }
    return "";
}

// Get an integer value from a JSON object by key.
func json_get_number(json string, key string) int {
    len := str_len(json);
    pos := skip_whitespace(json, 0);
    if (pos >= len) {
        return 0;
    }
    ch := str_char_at(json, pos);
    if (ch != 123) {
        return 0;
    }
    pos = pos + 1;
    while (pos < len) {
        pos = skip_whitespace(json, pos);
        if (pos >= len) {
            return 0;
        }
        ch = str_char_at(json, pos);
        if (ch == 125) {
            return 0;
        }
        k := parse_json_string_value(json, pos);
        pos = find_string_end(json, pos);
        pos = skip_whitespace(json, pos);
        if (pos >= len) {
            return 0;
        }
        ch = str_char_at(json, pos);
        if (ch == 58) {
            pos = pos + 1;
        }
        pos = skip_whitespace(json, pos);
        if (str_eq(k, key) == 1) {
            end := find_number_end(json, pos);
            return parse_json_number(json, pos, end);
        }
        pos = find_value_end(json, pos);
        pos = skip_whitespace(json, pos);
        if (pos < len) {
            ch = str_char_at(json, pos);
            if (ch == 44) {
                pos = pos + 1;
            }
        }
    }
    return 0;
}
