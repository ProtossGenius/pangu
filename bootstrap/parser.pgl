package main;

// ============================================================
// Pangu Bootstrap Parser
// Recursive descent parser: tokens → AST (parallel arrays)
//
// Node kinds (node_kind[]):
//   1=PROGRAM  2=PACKAGE  3=IMPORT  4=FUNC  5=PARAM
//   6=BLOCK  7=VARDECL  8=ASSIGN  9=RETURN  10=IF
//   11=WHILE  12=FOR  13=BREAK  14=CONTINUE  15=EXPRSTMT
//   16=BINOP  17=UNARYOP  18=CALL  19=IDENT  20=NUMBER
//   21=STRING  22=FIELDACCESS  23=INDEX  24=STRUCT_DEF
//   25=FIELD_DEF  26=STRUCT_LIT  27=FIELD_INIT  28=SWITCH
//   29=CASE  30=DEFAULT  31=IMPL  32=ENUM_DEF  33=ENUM_ITEM
//   34=TYPE_DECL  35=QUALIFIED_CALL  36=COMPOUND_ASSIGN
//   37=PREFIX_INCDEC  38=POSTFIX_INCDEC
//
// Token types from lexer: 0=EOF 1=KW 2=ID 3=NUM 4=STR 5=SYM
// ============================================================

// ----- AST node allocation -----

func node_new(kinds string, svals string, ivals string,
              lefts string, rights string, extras string,
              ncount string) int {
    nc := array_get(ncount, 0);
    array_set(kinds, nc, NodeKind::NK_NONE);
    str_array_set(svals, nc, "");
    array_set(ivals, nc, 0);
    array_set(lefts, nc, -1);
    array_set(rights, nc, -1);
    array_set(extras, nc, -1);
    array_set(ncount, 0, nc + 1);
    return nc;
}

func node_set(kinds string, svals string, ivals string,
              lefts string, rights string, extras string,
              id int, kind int, sval string, ival int,
              left int, right int, extra int) {
    array_set(kinds, id, kind);
    str_array_set(svals, id, sval);
    array_set(ivals, id, ival);
    array_set(lefts, id, left);
    array_set(rights, id, right);
    array_set(extras, id, extra);
}

// ----- Children list (linked via right pointer) -----
// We use a "list head/tail" stored in two temp arrays

func list_append(kinds string, svals string, ivals string,
                 lefts string, rights string, extras string,
                 ncount string,
                 head_arr string, tail_arr string, slot int,
                 child int) {
    // Wrap child in LISTNODE (kind=39) so that the child's own
    // rights field is never overwritten by sibling linking.
    w := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    array_set(kinds, w, NodeKind::NK_LIST);
    array_set(lefts, w, child);

    h := array_get(head_arr, slot);
    if (h == -1) {
        array_set(head_arr, slot, w);
        array_set(tail_arr, slot, w);
    } else {
        t := array_get(tail_arr, slot);
        array_set(rights, t, w);
        array_set(tail_arr, slot, w);
    }
}

// ============================================================
// Parser state: token position stored in pos_arr[0]
// ============================================================

func p_pos(pos_arr string) int {
    return array_get(pos_arr, 0);
}

func p_advance(pos_arr string) {
    array_set(pos_arr, 0, array_get(pos_arr, 0) + 1);
}

func p_tok_type(tok_types string, pos_arr string) int {
    return array_get(tok_types, p_pos(pos_arr));
}

func p_tok_val(tok_values string, pos_arr string) string {
    return str_array_get(tok_values, p_pos(pos_arr));
}

func p_tok_line(tok_lines string, pos_arr string) int {
    return array_get(tok_lines, p_pos(pos_arr));
}

// Check current token is a keyword with given value
func p_is_kw(tok_types string, tok_values string, pos_arr string, kw string) int {
    if (p_tok_type(tok_types, pos_arr) == TokenType::TT_KEYWORD && p_tok_val(tok_values, pos_arr) == kw) {
        return 1;
    }
    return 0;
}

// Check current token is a symbol with given value
func p_is_sym(tok_types string, tok_values string, pos_arr string, sym string) int {
    if (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && p_tok_val(tok_values, pos_arr) == sym) {
        return 1;
    }
    return 0;
}

// Expect and consume a symbol, error if not found
func p_expect_sym(tok_types string, tok_values string, tok_lines string,
                  pos_arr string, sym string, src_file string) {
    if (p_is_sym(tok_types, tok_values, pos_arr, sym) == 0) {
        print(src_file);
        print(":");
        print(int_to_str(p_tok_line(tok_lines, pos_arr)));
        print(": error: expected '");
        print(sym);
        print("' but got '");
        print(p_tok_val(tok_values, pos_arr));
        println("'");
        exit(1);
    }
    p_advance(pos_arr);
}

// Expect and consume a keyword
func p_expect_kw(tok_types string, tok_values string, tok_lines string,
                 pos_arr string, kw string, src_file string) {
    if (p_is_kw(tok_types, tok_values, pos_arr, kw) == 0) {
        print(src_file);
        print(":");
        print(int_to_str(p_tok_line(tok_lines, pos_arr)));
        print(": error: expected keyword '");
        print(kw);
        print("' but got '");
        print(p_tok_val(tok_values, pos_arr));
        println("'");
        exit(1);
    }
    p_advance(pos_arr);
}

// Expect and consume an identifier, return its name
func p_expect_ident(tok_types string, tok_values string, tok_lines string,
                    pos_arr string, src_file string) string {
    if (p_tok_type(tok_types, pos_arr) != TokenType::TT_IDENT) {
        print(src_file);
        print(":");
        print(int_to_str(p_tok_line(tok_lines, pos_arr)));
        print(": error: expected identifier but got '");
        print(p_tok_val(tok_values, pos_arr));
        println("'");
        exit(1);
    }
    name := p_tok_val(tok_values, pos_arr);
    p_advance(pos_arr);
    return name;
}

// ============================================================
// Expression parsing (precedence climbing)
// ============================================================

// Forward declarations are not needed since PGL resolves all
// functions in the same package. We use mutual recursion freely.

func parse_primary(tok_types string, tok_values string, tok_lines string,
                   pos_arr string, src_file string,
                   kinds string, svals string, ivals string,
                   lefts string, rights string, extras string,
                   ncount string) int {
    tt := p_tok_type(tok_types, pos_arr);
    tv := p_tok_val(tok_values, pos_arr);

    // Number literal
    if (tt == TokenType::TT_NUMBER) {
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_NUMBER, tv, 0, -1, -1, -1);
        p_advance(pos_arr);
        return nd;
    }

    // String literal
    if (tt == TokenType::TT_STRING) {
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_STRING, tv, 0, -1, -1, -1);
        p_advance(pos_arr);
        return nd;
    }

    // Parenthesized expression
    if (tt == TokenType::TT_SYMBOL && tv == "(") {
        p_advance(pos_arr);
        inner := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                            kinds, svals, ivals, lefts, rights, extras, ncount);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ")", src_file);
        return inner;
    }

    // Unary operators: ! - ++ --
    if (tt == TokenType::TT_SYMBOL && (tv == "!" || tv == "-" || tv == "++" || tv == "--")) {
        p_advance(pos_arr);
        operand := parse_unary(tok_types, tok_values, tok_lines, pos_arr, src_file,
                               kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        if (tv == "++" || tv == "--") {
            node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_PREFIX_INCDEC, tv, 0, operand, -1, -1);
        } else {
            node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_UNARYOP, tv, 0, operand, -1, -1);
        }
        return nd;
    }

    // Identifier (may be function call, struct literal, or plain var)
    if (tt == TokenType::TT_IDENT) {
        name := tv;
        p_advance(pos_arr);

        // Function call: name(...)
        if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) {
            return parse_call_args(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                   kinds, svals, ivals, lefts, rights, extras, ncount, name);
        }

        // Struct literal: Name{field: val, ...}
        if (p_is_sym(tok_types, tok_values, pos_arr, "{") == 1) {
            // Check if next token after { is ident followed by :
            // to distinguish from block statement
            saved_pos := p_pos(pos_arr);
            p_advance(pos_arr); // skip {
            if (p_tok_type(tok_types, pos_arr) == TokenType::TT_IDENT) {
                after_ident := p_pos(pos_arr) + 1;
                if (array_get(tok_types, after_ident) == 5 && str_array_get(tok_values, after_ident) == ":") {
                    // It's a struct literal
                    array_set(pos_arr, 0, saved_pos);
                    return parse_struct_lit(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                           kinds, svals, ivals, lefts, rights, extras, ncount, name);
                }
            }
            // Also handle empty struct literal Name{}
            if (p_is_sym(tok_types, tok_values, pos_arr, "}") == 1) {
                nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
                node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_STRUCT_LIT, name, 0, -1, -1, -1);
                p_advance(pos_arr); // skip }
                return nd;
            }
            // Not a struct literal, restore position
            array_set(pos_arr, 0, saved_pos);
        }

        // Plain identifier
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_IDENT, name, 0, -1, -1, -1);
        return nd;
    }

    // true/false as identifiers
    if (tt == TokenType::TT_KEYWORD && (tv == "true" || tv == "false")) {
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_IDENT, tv, 0, -1, -1, -1);
        p_advance(pos_arr);
        return nd;
    }

    print(src_file);
    print(":");
    print(int_to_str(p_tok_line(tok_lines, pos_arr)));
    print(": error: unexpected token '");
    print(tv);
    println("' in expression");
    exit(1);
    return -1;
}

func parse_call_args(tok_types string, tok_values string, tok_lines string,
                     pos_arr string, src_file string,
                     kinds string, svals string, ivals string,
                     lefts string, rights string, extras string,
                     ncount string, name string) int {
    p_advance(pos_arr); // skip (
    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);
    arg_count := 0;

    if (p_is_sym(tok_types, tok_values, pos_arr, ")") == 0) {
        arg := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                          kinds, svals, ivals, lefts, rights, extras, ncount);
        list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, arg);
        arg_count = arg_count + 1;
        while (p_is_sym(tok_types, tok_values, pos_arr, ",") == 1) {
            p_advance(pos_arr);
            arg = parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                             kinds, svals, ivals, lefts, rights, extras, ncount);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, arg);
            arg_count = arg_count + 1;
        }
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ")", src_file);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd,
             18, name, arg_count, array_get(head_arr, 0), -1, -1);
    return nd;
}

func parse_struct_lit(tok_types string, tok_values string, tok_lines string,
                      pos_arr string, src_file string,
                      kinds string, svals string, ivals string,
                      lefts string, rights string, extras string,
                      ncount string, name string) int {
    p_advance(pos_arr); // skip {
    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);

    while (p_is_sym(tok_types, tok_values, pos_arr, "}") == 0) {
        fname := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ":", src_file);
        fval := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
        fi := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, fi, NodeKind::NK_FIELD_INIT, fname, 0, fval, -1, -1);
        list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, fi);
        if (p_is_sym(tok_types, tok_values, pos_arr, ",") == 1) {
            p_advance(pos_arr);
        }
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "}", src_file);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd,
             26, name, 0, array_get(head_arr, 0), -1, -1);
    return nd;
}

// Postfix: field access, qualified call, postfix ++/--
func parse_postfix(tok_types string, tok_values string, tok_lines string,
                   pos_arr string, src_file string,
                   kinds string, svals string, ivals string,
                   lefts string, rights string, extras string,
                   ncount string) int {
    left := parse_primary(tok_types, tok_values, tok_lines, pos_arr, src_file,
                          kinds, svals, ivals, lefts, rights, extras, ncount);

    done := 0;
    while (done == 0) {
        // Enum::Variant access
        if (p_is_sym(tok_types, tok_values, pos_arr, "::") == 1) {
            p_advance(pos_arr);
            variant := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
            nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_FIELDACCESS, variant, 0, left, -1, -1);
            left = nd;
        }
        // Field access or qualified call: expr.ident or expr.ident(...)
        else if (p_is_sym(tok_types, tok_values, pos_arr, ".") == 1) {
            p_advance(pos_arr);
            field := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);

            // Qualified call: obj.method(args)
            if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) {
                obj_name := str_array_get(svals, left);
                qname := "${obj_name}.${field}";
                left = parse_call_args(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                       kinds, svals, ivals, lefts, rights, extras, ncount, qname);
            } else {
                nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
                node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_FIELDACCESS, field, 0, left, -1, -1);
                left = nd;
            }
        }
        // Postfix ++ / --
        else if (p_is_sym(tok_types, tok_values, pos_arr, "++") == 1 || p_is_sym(tok_types, tok_values, pos_arr, "--") == 1) {
            op := p_tok_val(tok_values, pos_arr);
            p_advance(pos_arr);
            nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_POSTFIX_INCDEC, op, 0, left, -1, -1);
            left = nd;
        }
        else {
            done = 1;
        }
    }
    return left;
}

func parse_unary(tok_types string, tok_values string, tok_lines string,
                 pos_arr string, src_file string,
                 kinds string, svals string, ivals string,
                 lefts string, rights string, extras string,
                 ncount string) int {
    tv := p_tok_val(tok_values, pos_arr);
    if (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && (tv == "!" || tv == "-" || tv == "++" || tv == "--")) {
        p_advance(pos_arr);
        operand := parse_unary(tok_types, tok_values, tok_lines, pos_arr, src_file,
                               kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        if (tv == "++" || tv == "--") {
            node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_PREFIX_INCDEC, tv, 0, operand, -1, -1);
        } else {
            node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_UNARYOP, tv, 0, operand, -1, -1);
        }
        return nd;
    }
    return parse_postfix(tok_types, tok_values, tok_lines, pos_arr, src_file,
                         kinds, svals, ivals, lefts, rights, extras, ncount);
}

// Binary expression: precedence levels
// 1: || , 2: && , 3: == != , 4: < > <= >= , 5: + - , 6: * / %

func parse_mul(tok_types string, tok_values string, tok_lines string,
               pos_arr string, src_file string,
               kinds string, svals string, ivals string,
               lefts string, rights string, extras string,
               ncount string) int {
    left := parse_unary(tok_types, tok_values, tok_lines, pos_arr, src_file,
                        kinds, svals, ivals, lefts, rights, extras, ncount);
    tv := p_tok_val(tok_values, pos_arr);
    while (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && (tv == "*" || tv == "/" || tv == "%")) {
        op := tv;
        p_advance(pos_arr);
        right := parse_unary(tok_types, tok_values, tok_lines, pos_arr, src_file,
                             kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BINOP, op, 0, left, right, -1);
        left = nd;
        tv = p_tok_val(tok_values, pos_arr);
    }
    return left;
}

func parse_add(tok_types string, tok_values string, tok_lines string,
               pos_arr string, src_file string,
               kinds string, svals string, ivals string,
               lefts string, rights string, extras string,
               ncount string) int {
    left := parse_mul(tok_types, tok_values, tok_lines, pos_arr, src_file,
                      kinds, svals, ivals, lefts, rights, extras, ncount);
    tv := p_tok_val(tok_values, pos_arr);
    while (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && (tv == "+" || tv == "-")) {
        op := tv;
        p_advance(pos_arr);
        right := parse_mul(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BINOP, op, 0, left, right, -1);
        left = nd;
        tv = p_tok_val(tok_values, pos_arr);
    }
    return left;
}

func parse_rel(tok_types string, tok_values string, tok_lines string,
               pos_arr string, src_file string,
               kinds string, svals string, ivals string,
               lefts string, rights string, extras string,
               ncount string) int {
    left := parse_add(tok_types, tok_values, tok_lines, pos_arr, src_file,
                      kinds, svals, ivals, lefts, rights, extras, ncount);
    tv := p_tok_val(tok_values, pos_arr);
    while (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && (tv == "<" || tv == ">" || tv == "<=" || tv == ">=")) {
        op := tv;
        p_advance(pos_arr);
        right := parse_add(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BINOP, op, 0, left, right, -1);
        left = nd;
        tv = p_tok_val(tok_values, pos_arr);
    }
    return left;
}

func parse_eq(tok_types string, tok_values string, tok_lines string,
              pos_arr string, src_file string,
              kinds string, svals string, ivals string,
              lefts string, rights string, extras string,
              ncount string) int {
    left := parse_rel(tok_types, tok_values, tok_lines, pos_arr, src_file,
                      kinds, svals, ivals, lefts, rights, extras, ncount);
    tv := p_tok_val(tok_values, pos_arr);
    while (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && (tv == "==" || tv == "!=")) {
        op := tv;
        p_advance(pos_arr);
        right := parse_rel(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BINOP, op, 0, left, right, -1);
        left = nd;
        tv = p_tok_val(tok_values, pos_arr);
    }
    return left;
}

func parse_and(tok_types string, tok_values string, tok_lines string,
               pos_arr string, src_file string,
               kinds string, svals string, ivals string,
               lefts string, rights string, extras string,
               ncount string) int {
    left := parse_eq(tok_types, tok_values, tok_lines, pos_arr, src_file,
                     kinds, svals, ivals, lefts, rights, extras, ncount);
    while (p_is_sym(tok_types, tok_values, pos_arr, "&&") == 1) {
        p_advance(pos_arr);
        right := parse_eq(tok_types, tok_values, tok_lines, pos_arr, src_file,
                          kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BINOP, "&&", 0, left, right, -1);
        left = nd;
    }
    return left;
}

func parse_or(tok_types string, tok_values string, tok_lines string,
              pos_arr string, src_file string,
              kinds string, svals string, ivals string,
              lefts string, rights string, extras string,
              ncount string) int {
    left := parse_and(tok_types, tok_values, tok_lines, pos_arr, src_file,
                      kinds, svals, ivals, lefts, rights, extras, ncount);
    while (p_is_sym(tok_types, tok_values, pos_arr, "||") == 1) {
        p_advance(pos_arr);
        right := parse_and(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BINOP, "||", 0, left, right, -1);
        left = nd;
    }
    return left;
}

func parse_expr(tok_types string, tok_values string, tok_lines string,
                pos_arr string, src_file string,
                kinds string, svals string, ivals string,
                lefts string, rights string, extras string,
                ncount string) int {
    cond := parse_or(tok_types, tok_values, tok_lines, pos_arr, src_file,
                     kinds, svals, ivals, lefts, rights, extras, ncount);
    // Ternary: cond ? then_expr : else_expr
    if (p_is_sym(tok_types, tok_values, pos_arr, "?") == 1) {
        p_advance(pos_arr);
        then_expr := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                kinds, svals, ivals, lefts, rights, extras, ncount);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ":", src_file);
        else_expr := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_TERNARY, "", 0, cond, then_expr, else_expr);
        return nd;
    }
    return cond;
}

// ============================================================
// Statement parsing
// ============================================================

func parse_block(tok_types string, tok_values string, tok_lines string,
                 pos_arr string, src_file string,
                 kinds string, svals string, ivals string,
                 lefts string, rights string, extras string,
                 ncount string) int {
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "{", src_file);
    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);

    while (p_is_sym(tok_types, tok_values, pos_arr, "}") == 0 && p_tok_type(tok_types, pos_arr) != TokenType::TT_EOF) {
        stmt := parse_stmt(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
        if (stmt != -1) {
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount,
                        head_arr, tail_arr, 0, stmt);
        }
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "}", src_file);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BLOCK, "", 0, array_get(head_arr, 0), -1, -1);
    return nd;
}

func parse_stmt(tok_types string, tok_values string, tok_lines string,
                pos_arr string, src_file string,
                kinds string, svals string, ivals string,
                lefts string, rights string, extras string,
                ncount string) int {
    tt := p_tok_type(tok_types, pos_arr);
    tv := p_tok_val(tok_values, pos_arr);

    // Skip stray semicolons
    if (tt == TokenType::TT_SYMBOL && tv == ";") {
        p_advance(pos_arr);
        return -1;
    }

    // return [expr] ;
    if (tt == TokenType::TT_KEYWORD && tv == "return") {
        p_advance(pos_arr);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        val := -1;
        if (p_is_sym(tok_types, tok_values, pos_arr, ";") == 0) {
            val = parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                             kinds, svals, ivals, lefts, rights, extras, ncount);
        }
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_RETURN, "", 0, val, -1, -1);
        return nd;
    }

    // break ;
    if (tt == TokenType::TT_KEYWORD && tv == "break") {
        p_advance(pos_arr);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_BREAK, "", 0, -1, -1, -1);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        return nd;
    }

    // continue ;
    if (tt == TokenType::TT_KEYWORD && tv == "continue") {
        p_advance(pos_arr);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_CONTINUE, "", 0, -1, -1, -1);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        return nd;
    }

    // if (expr) block [else if ...]* [else block]
    if (tt == TokenType::TT_KEYWORD && tv == "if") {
        return parse_if(tok_types, tok_values, tok_lines, pos_arr, src_file,
                        kinds, svals, ivals, lefts, rights, extras, ncount);
    }

    // while (expr) block
    if (tt == TokenType::TT_KEYWORD && tv == "while") {
        return parse_while(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
    }

    // for (init; cond; step) block
    if (tt == TokenType::TT_KEYWORD && tv == "for") {
        return parse_for(tok_types, tok_values, tok_lines, pos_arr, src_file,
                         kinds, svals, ivals, lefts, rights, extras, ncount);
    }

    // switch (expr) { case ... }
    if (tt == TokenType::TT_KEYWORD && tv == "switch") {
        return parse_switch(tok_types, tok_values, tok_lines, pos_arr, src_file,
                            kinds, svals, ivals, lefts, rights, extras, ncount);
    }

    // Block statement
    if (tt == TokenType::TT_SYMBOL && tv == "{") {
        return parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
    }

    // Identifier-led statement: vardecl (:=), assignment (=, +=, etc.), or expr stmt
    if (tt == TokenType::TT_IDENT) {
        return parse_ident_stmt(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                kinds, svals, ivals, lefts, rights, extras, ncount);
    }

    // Prefix ++/-- as statements
    if (tt == TokenType::TT_SYMBOL && (tv == "++" || tv == "--")) {
        expr := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                           kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_EXPRSTMT, "", 0, expr, -1, -1);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        return nd;
    }

    print(src_file);
    print(":");
    print(int_to_str(p_tok_line(tok_lines, pos_arr)));
    print(": error: unexpected token '");
    print(tv);
    println("' at start of statement");
    exit(1);
    return -1;
}

func parse_ident_stmt(tok_types string, tok_values string, tok_lines string,
                      pos_arr string, src_file string,
                      kinds string, svals string, ivals string,
                      lefts string, rights string, extras string,
                      ncount string) int {
    // Parse the left-hand expression (could be field access chain)
    lhs := parse_postfix(tok_types, tok_values, tok_lines, pos_arr, src_file,
                         kinds, svals, ivals, lefts, rights, extras, ncount);
    tv := p_tok_val(tok_values, pos_arr);

    // Variable declaration: name := expr ;
    if (tv == ":=") {
        name := str_array_get(svals, lhs);
        p_advance(pos_arr);
        val := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                          kinds, svals, ivals, lefts, rights, extras, ncount);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_VARDECL, name, 0, val, -1, -1);
        return nd;
    }

    // Assignment: lhs = expr ;
    if (tv == "=") {
        p_advance(pos_arr);
        val := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                          kinds, svals, ivals, lefts, rights, extras, ncount);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_ASSIGN, "", 0, lhs, val, -1);
        return nd;
    }

    // Compound assignment: += -= *= /= %=
    if (tv == "+=" || tv == "-=" || tv == "*=" || tv == "/=" || tv == "%=") {
        op := tv;
        p_advance(pos_arr);
        val := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                          kinds, svals, ivals, lefts, rights, extras, ncount);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_COMPOUND_ASSIGN, op, 0, lhs, val, -1);
        return nd;
    }

    // Postfix ++/-- as statement
    if (tv == "++" || tv == "--") {
        op := tv;
        p_advance(pos_arr);
        post_nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, post_nd, NodeKind::NK_POSTFIX_INCDEC, op, 0, lhs, -1, -1);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_EXPRSTMT, "", 0, post_nd, -1, -1);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
        return nd;
    }

    // Expression statement (function call etc.)
    // The lhs is already parsed; if it's followed by ; we're done
    if (p_is_sym(tok_types, tok_values, pos_arr, ";") == 1) {
        p_advance(pos_arr);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_EXPRSTMT, "", 0, lhs, -1, -1);
        return nd;
    }

    // Could be part of a larger expression that wasn't fully parsed
    // (e.g., binary op). Re-parse as full expression is tricky here.
    // For bootstrap, most expression statements are function calls which
    // parse_postfix handles. Emit as expression statement.
    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_EXPRSTMT, "", 0, lhs, -1, -1);
    if (p_is_sym(tok_types, tok_values, pos_arr, ";") == 1) {
        p_advance(pos_arr);
    }
    return nd;
}

func parse_if(tok_types string, tok_values string, tok_lines string,
              pos_arr string, src_file string,
              kinds string, svals string, ivals string,
              lefts string, rights string, extras string,
              ncount string) int {
    p_advance(pos_arr); // skip 'if'
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "(", src_file);
    cond := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                       kinds, svals, ivals, lefts, rights, extras, ncount);
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ")", src_file);
    then_block := parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                              kinds, svals, ivals, lefts, rights, extras, ncount);
    else_block := -1;

    if (p_is_kw(tok_types, tok_values, pos_arr, "else") == 1) {
        p_advance(pos_arr); // skip 'else'
        if (p_is_kw(tok_types, tok_values, pos_arr, "if") == 1) {
            // else if → recursive
            else_block = parse_if(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                  kinds, svals, ivals, lefts, rights, extras, ncount);
        } else {
            else_block = parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                     kinds, svals, ivals, lefts, rights, extras, ncount);
        }
    }

    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_IF, "", 0, cond, then_block, else_block);
    return nd;
}

func parse_while(tok_types string, tok_values string, tok_lines string,
                 pos_arr string, src_file string,
                 kinds string, svals string, ivals string,
                 lefts string, rights string, extras string,
                 ncount string) int {
    p_advance(pos_arr); // skip 'while'
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "(", src_file);
    cond := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                       kinds, svals, ivals, lefts, rights, extras, ncount);
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ")", src_file);
    body := parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                        kinds, svals, ivals, lefts, rights, extras, ncount);

    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_WHILE, "", 0, cond, body, -1);
    return nd;
}

func parse_for(tok_types string, tok_values string, tok_lines string,
               pos_arr string, src_file string,
               kinds string, svals string, ivals string,
               lefts string, rights string, extras string,
               ncount string) int {
    p_advance(pos_arr); // skip 'for'

    // for { body } — infinite loop
    if (p_is_sym(tok_types, tok_values, pos_arr, "{") == 1) {
        body := parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                            kinds, svals, ivals, lefts, rights, extras, ncount);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_INDEX, "", 0, -1, body, -1);
        return nd;
    }

    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "(", src_file);

    // Init: ident := expr or ident = expr
    init_nd := -1;
    if (p_is_sym(tok_types, tok_values, pos_arr, ";") == 0) {
        name := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
        tv := p_tok_val(tok_values, pos_arr);
        if (tv == ":=") {
            p_advance(pos_arr);
            val := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                              kinds, svals, ivals, lefts, rights, extras, ncount);
            init_nd = node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, init_nd, NodeKind::NK_VARDECL, name, 0, val, -1, -1);
        } else if (tv == "=") {
            p_advance(pos_arr);
            val := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                              kinds, svals, ivals, lefts, rights, extras, ncount);
            lhs_nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, lhs_nd, NodeKind::NK_IDENT, name, 0, -1, -1, -1);
            init_nd = node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, init_nd, NodeKind::NK_ASSIGN, "", 0, lhs_nd, val, -1);
        }
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);

    // Condition
    cond := -1;
    if (p_is_sym(tok_types, tok_values, pos_arr, ";") == 0) {
        cond = parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                          kinds, svals, ivals, lefts, rights, extras, ncount);
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);

    // Step: could be ++i, i++, i = i + 1, etc.
    step := -1;
    if (p_is_sym(tok_types, tok_values, pos_arr, ")") == 0) {
        step_tv := p_tok_val(tok_values, pos_arr);
        if (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && (step_tv == "++" || step_tv == "--")) {
            p_advance(pos_arr);
            operand := parse_postfix(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                     kinds, svals, ivals, lefts, rights, extras, ncount);
            step = node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, step, NodeKind::NK_PREFIX_INCDEC, step_tv, 0, operand, -1, -1);
        } else {
            operand := parse_postfix(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                     kinds, svals, ivals, lefts, rights, extras, ncount);
            // parse_postfix may have already consumed i++ / i--
            op_kind := array_get(kinds, operand);
            if (op_kind == 38 || op_kind == 37) {
                step = operand;
            } else {
            step_tv2 := p_tok_val(tok_values, pos_arr);
            if (step_tv2 == "++" || step_tv2 == "--") {
                p_advance(pos_arr);
                step = node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
                node_set(kinds, svals, ivals, lefts, rights, extras, step, NodeKind::NK_POSTFIX_INCDEC, step_tv2, 0, operand, -1, -1);
            } else if (step_tv2 == "=" || step_tv2 == "+=" || step_tv2 == "-=") {
                p_advance(pos_arr);
                rhs := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                  kinds, svals, ivals, lefts, rights, extras, ncount);
                if (step_tv2 == "=") {
                    step = node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
                    node_set(kinds, svals, ivals, lefts, rights, extras, step, NodeKind::NK_ASSIGN, "", 0, operand, rhs, -1);
                } else {
                    step = node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
                    node_set(kinds, svals, ivals, lefts, rights, extras, step, NodeKind::NK_COMPOUND_ASSIGN, step_tv2, 0, operand, rhs, -1);
                }
            }
            }
        }
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ")", src_file);

    body := parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                        kinds, svals, ivals, lefts, rights, extras, ncount);

    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    // left=init, right=body, extra=cond; step stored via ivals trick
    // For simplicity: left=cond, right=body, extra=init; store step as right of init? No...
    // Let's use: sval="", ival=step_id, left=cond, right=body, extra=init
    step_id := -1;
    if (step != -1) { step_id = step; }
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_FOR, "", step_id, cond, body, init_nd);
    return nd;
}

func parse_switch(tok_types string, tok_values string, tok_lines string,
                  pos_arr string, src_file string,
                  kinds string, svals string, ivals string,
                  lefts string, rights string, extras string,
                  ncount string) int {
    p_advance(pos_arr); // skip 'switch'
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "(", src_file);
    cond := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                       kinds, svals, ivals, lefts, rights, extras, ncount);
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ")", src_file);
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "{", src_file);

    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);

    while (p_is_sym(tok_types, tok_values, pos_arr, "}") == 0 && p_tok_type(tok_types, pos_arr) != TokenType::TT_EOF) {
        if (p_is_kw(tok_types, tok_values, pos_arr, "case") == 1) {
            p_advance(pos_arr);
            val := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                              kinds, svals, ivals, lefts, rights, extras, ncount);
            p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ":", src_file);
            body := parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                kinds, svals, ivals, lefts, rights, extras, ncount);
            c := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, c, NodeKind::NK_CASE, "", 0, val, body, -1);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, c);
        }
        else if (p_is_kw(tok_types, tok_values, pos_arr, "default") == 1) {
            p_advance(pos_arr);
            p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ":", src_file);
            body := parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                kinds, svals, ivals, lefts, rights, extras, ncount);
            c := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, c, NodeKind::NK_DEFAULT, "", 0, body, -1, -1);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, c);
        }
        else {
            print(src_file);
            print(":");
            print(int_to_str(p_tok_line(tok_lines, pos_arr)));
            println(": error: expected 'case' or 'default' in switch");
            exit(1);
        }
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "}", src_file);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_SWITCH, "", 0, cond, array_get(head_arr, 0), -1);
    return nd;
}

// ============================================================
// Top-level declarations
// ============================================================

func parse_type_ref(tok_types string, tok_values string, tok_lines string,
                    pos_arr string, src_file string) string {
    // Simple type reference: just an identifier for now
    name := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
    return name;
}

func parse_params(tok_types string, tok_values string, tok_lines string,
                  pos_arr string, src_file string,
                  kinds string, svals string, ivals string,
                  lefts string, rights string, extras string,
                  ncount string,
                  head_arr string, tail_arr string, slot int) int {
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "(", src_file);
    count := 0;
    while (p_is_sym(tok_types, tok_values, pos_arr, ")") == 0) {
        if (count > 0) {
            p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ",", src_file);
        }
        pname := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
        ptype := parse_type_ref(tok_types, tok_values, tok_lines, pos_arr, src_file);
        pnd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, pnd, NodeKind::NK_PARAM, pname, 0, -1, -1, -1);
        str_array_set(svals, pnd, "${pname}:${ptype}");
        list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, slot, pnd);
        count = count + 1;
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ")", src_file);
    return count;
}

func parse_func_decl(tok_types string, tok_values string, tok_lines string,
                     pos_arr string, src_file string,
                     kinds string, svals string, ivals string,
                     lefts string, rights string, extras string,
                     ncount string) int {
    p_advance(pos_arr); // skip 'func'
    name := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);

    // Parameters
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);
    param_count := parse_params(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                kinds, svals, ivals, lefts, rights, extras, ncount,
                                head_arr, tail_arr, 0);

    // Return type (optional)
    ret_type := "";
    if (p_is_sym(tok_types, tok_values, pos_arr, "{") == 0) {
        if (p_tok_type(tok_types, pos_arr) == TokenType::TT_IDENT) {
            ret_type = p_tok_val(tok_values, pos_arr);
            p_advance(pos_arr);
        } else if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) {
            // Multi-return: skip for bootstrap
            p_advance(pos_arr);
            while (p_is_sym(tok_types, tok_values, pos_arr, ")") == 0) {
                p_advance(pos_arr);
            }
            p_advance(pos_arr);
        }
    }

    // Body
    body := parse_block(tok_types, tok_values, tok_lines, pos_arr, src_file,
                        kinds, svals, ivals, lefts, rights, extras, ncount);

    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_FUNC,
             "${name}:${ret_type}",
             param_count, array_get(head_arr, 0), body, -1);
    return nd;
}

func parse_struct_decl(tok_types string, tok_values string, tok_lines string,
                       pos_arr string, src_file string,
                       kinds string, svals string, ivals string,
                       lefts string, rights string, extras string,
                       ncount string, name string) int {
    p_advance(pos_arr); // skip 'struct'
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "{", src_file);
    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);

    while (p_is_sym(tok_types, tok_values, pos_arr, "}") == 0) {
        fname := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
        ftype := parse_type_ref(tok_types, tok_values, tok_lines, pos_arr, src_file);
        if (p_is_sym(tok_types, tok_values, pos_arr, ";") == 1) { p_advance(pos_arr); }
        fnd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        node_set(kinds, svals, ivals, lefts, rights, extras, fnd, NodeKind::NK_FIELD_DEF, "${fname}:${ftype}", 0, -1, -1, -1);
        list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, fnd);
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "}", src_file);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_STRUCT_DEF, name, 0, array_get(head_arr, 0), -1, -1);
    return nd;
}

func skip_brace_block(tok_types string, tok_values string, pos_arr string) {
    depth := 1;
    p_advance(pos_arr); // skip opening {
    while (depth > 0 && p_tok_type(tok_types, pos_arr) != TokenType::TT_EOF) {
        tv := p_tok_val(tok_values, pos_arr);
        if (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && tv == "{") { depth = depth + 1; }
        if (p_tok_type(tok_types, pos_arr) == TokenType::TT_SYMBOL && tv == "}") { depth = depth - 1; }
        p_advance(pos_arr);
    }
}

func parse_type_decl(tok_types string, tok_values string, tok_lines string,
                     pos_arr string, src_file string,
                     kinds string, svals string, ivals string,
                     lefts string, rights string, extras string,
                     ncount string) int {
    p_advance(pos_arr); // skip 'type'
    name := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
    tv := p_tok_val(tok_values, pos_arr);

    if (tv == "struct") {
        return parse_struct_decl(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                 kinds, svals, ivals, lefts, rights, extras, ncount, name);
    }

    if (tv == "enum") {
        p_advance(pos_arr);
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "{", src_file);
        nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
        head_arr := make_array(2);
        tail_arr := make_array(2);
        array_set(head_arr, 0, -1);
        while (p_is_sym(tok_types, tok_values, pos_arr, "}") == 0) {
            ename := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
            end := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, end, NodeKind::NK_ENUM_ITEM, ename, 0, -1, -1, -1);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, end);
            if (p_is_sym(tok_types, tok_values, pos_arr, ",") == 1) { p_advance(pos_arr); }
        }
        p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "}", src_file);
        node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_ENUM_DEF, name, 0, array_get(head_arr, 0), -1, -1);
        return nd;
    }

    // Other type decls: func, pipeline, interface → skip
    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_TYPE_DECL, "${name}:${tv}", 0, -1, -1, -1);
    p_advance(pos_arr); // skip subkind keyword

    // Skip parameters/body
    if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) {
        depth := 1;
        p_advance(pos_arr);
        while (depth > 0 && p_tok_type(tok_types, pos_arr) != TokenType::TT_EOF) {
            if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) { depth = depth + 1; }
            if (p_is_sym(tok_types, tok_values, pos_arr, ")") == 1) { depth = depth - 1; }
            p_advance(pos_arr);
        }
        // Check for return type params
        if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) {
            depth = 1;
            p_advance(pos_arr);
            while (depth > 0 && p_tok_type(tok_types, pos_arr) != TokenType::TT_EOF) {
                if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) { depth = depth + 1; }
                if (p_is_sym(tok_types, tok_values, pos_arr, ")") == 1) { depth = depth - 1; }
                p_advance(pos_arr);
            }
        }
    }
    if (p_is_sym(tok_types, tok_values, pos_arr, ";") == 1) {
        p_advance(pos_arr);
    } else if (p_is_sym(tok_types, tok_values, pos_arr, "{") == 1) {
        skip_brace_block(tok_types, tok_values, pos_arr);
    }
    return nd;
}

func parse_impl_decl(tok_types string, tok_values string, tok_lines string,
                     pos_arr string, src_file string,
                     kinds string, svals string, ivals string,
                     lefts string, rights string, extras string,
                     ncount string) int {
    p_advance(pos_arr); // skip 'impl'
    // impl TypeName Role [modifiers] { func ... }
    type_name := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
    role := "";
    if (p_tok_type(tok_types, pos_arr) == TokenType::TT_IDENT) {
        role = p_tok_val(tok_values, pos_arr);
        p_advance(pos_arr);
    }
    // Skip modifiers
    while (p_tok_type(tok_types, pos_arr) == TokenType::TT_IDENT && p_is_sym(tok_types, tok_values, pos_arr, "{") == 0) {
        p_advance(pos_arr);
    }

    // Parse impl body: contains func declarations
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "{", src_file);
    nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);

    while (p_is_sym(tok_types, tok_values, pos_arr, "}") == 0 && p_tok_type(tok_types, pos_arr) != TokenType::TT_EOF) {
        if (p_is_kw(tok_types, tok_values, pos_arr, "func") == 1) {
            fnd := parse_func_decl(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                   kinds, svals, ivals, lefts, rights, extras, ncount);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, fnd);
        } else {
            p_advance(pos_arr);
        }
    }
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "}", src_file);
    node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_IMPL,
             "${type_name}:${role}", 0, array_get(head_arr, 0), -1, -1);
    return nd;
}

// ============================================================
// Program parsing
// ============================================================

func parse_program(tok_types string, tok_values string, tok_lines string,
                   tok_count int, pos_arr string, src_file string,
                   kinds string, svals string, ivals string,
                   lefts string, rights string, extras string,
                   ncount string) int {
    root := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    head_arr := make_array(2);
    tail_arr := make_array(2);
    array_set(head_arr, 0, -1);

    // package name ;
    p_expect_kw(tok_types, tok_values, tok_lines, pos_arr, "package", src_file);
    pkg_name := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
    p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
    pkg := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
    node_set(kinds, svals, ivals, lefts, rights, extras, pkg, NodeKind::NK_PACKAGE, pkg_name, 0, -1, -1, -1);
    list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, pkg);

    // Parse top-level declarations
    while (p_tok_type(tok_types, pos_arr) != TokenType::TT_EOF) {
        tt := p_tok_type(tok_types, pos_arr);
        tv := p_tok_val(tok_values, pos_arr);

        // import "path" [as alias] ;
        if (tt == TokenType::TT_KEYWORD && tv == "import") {
            p_advance(pos_arr);
            path := p_tok_val(tok_values, pos_arr);
            p_advance(pos_arr); // skip string
            alias := "";
            if (p_is_kw(tok_types, tok_values, pos_arr, "as") == 1) {
                p_advance(pos_arr);
                alias = p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
            }
            p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
            imp := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, imp, NodeKind::NK_IMPORT, path, 0, -1, -1, -1);
            str_array_set(svals, imp, "${path}:${alias}");
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, imp);
        }
        // func declaration
        else if (tt == TokenType::TT_KEYWORD && tv == "func") {
            fnd := parse_func_decl(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                   kinds, svals, ivals, lefts, rights, extras, ncount);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, fnd);
        }
        // type declaration
        else if (tt == TokenType::TT_KEYWORD && tv == "type") {
            tnd := parse_type_decl(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                   kinds, svals, ivals, lefts, rights, extras, ncount);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, tnd);
        }
        // impl block
        else if (tt == TokenType::TT_KEYWORD && tv == "impl") {
            ind := parse_impl_decl(tok_types, tok_values, tok_lines, pos_arr, src_file,
                                   kinds, svals, ivals, lefts, rights, extras, ncount);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, ind);
        }
        // const declaration: const NAME = value;
        else if (tt == TokenType::TT_KEYWORD && tv == "const") {
            p_advance(pos_arr);
            cname := p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
            p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, "=", src_file);
            cval := parse_expr(tok_types, tok_values, tok_lines, pos_arr, src_file,
                               kinds, svals, ivals, lefts, rights, extras, ncount);
            p_expect_sym(tok_types, tok_values, tok_lines, pos_arr, ";", src_file);
            nd := node_new(kinds, svals, ivals, lefts, rights, extras, ncount);
            node_set(kinds, svals, ivals, lefts, rights, extras, nd, NodeKind::NK_CONST_DECL, cname, 0, cval, -1, -1);
            list_append(kinds, svals, ivals, lefts, rights, extras, ncount, head_arr, tail_arr, 0, nd);
        }
        // pipeline declaration (skip for bootstrap)
        else if (tt == TokenType::TT_KEYWORD && tv == "pipeline") {
            p_advance(pos_arr);
            p_expect_ident(tok_types, tok_values, tok_lines, pos_arr, src_file);
            // Skip params
            if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) {
                depth := 1;
                p_advance(pos_arr);
                while (depth > 0) { 
                    if (p_is_sym(tok_types, tok_values, pos_arr, "(") == 1) { depth = depth + 1; }
                    if (p_is_sym(tok_types, tok_values, pos_arr, ")") == 1) { depth = depth - 1; }
                    p_advance(pos_arr);
                }
            }
            if (p_is_sym(tok_types, tok_values, pos_arr, "{") == 1) {
                skip_brace_block(tok_types, tok_values, pos_arr);
            }
        }
        // Skip stray semicolons
        else if (tt == TokenType::TT_SYMBOL && tv == ";") {
            p_advance(pos_arr);
        }
        else {
            print(src_file);
            print(":");
            print(int_to_str(p_tok_line(tok_lines, pos_arr)));
            print(": error: unexpected top-level token '");
            print(tv);
            println("'");
            exit(1);
        }
    }

    node_set(kinds, svals, ivals, lefts, rights, extras, root, NodeKind::NK_PROGRAM, pkg_name, 0, array_get(head_arr, 0), -1, -1);
    return root;
}

// ============================================================
// AST dump (for debugging)
// ============================================================

func node_kind_name(k int) string {
    if (k == NodeKind::NK_PROGRAM) { return "PROGRAM"; }
    if (k == NodeKind::NK_PACKAGE) { return "PACKAGE"; }
    if (k == NodeKind::NK_IMPORT) { return "IMPORT"; }
    if (k == NodeKind::NK_FUNC) { return "FUNC"; }
    if (k == NodeKind::NK_PARAM) { return "PARAM"; }
    if (k == NodeKind::NK_BLOCK) { return "BLOCK"; }
    if (k == NodeKind::NK_VARDECL) { return "VARDECL"; }
    if (k == NodeKind::NK_ASSIGN) { return "ASSIGN"; }
    if (k == NodeKind::NK_RETURN) { return "RETURN"; }
    if (k == NodeKind::NK_IF) { return "IF"; }
    if (k == NodeKind::NK_WHILE) { return "WHILE"; }
    if (k == NodeKind::NK_FOR) { return "FOR"; }
    if (k == NodeKind::NK_BREAK) { return "BREAK"; }
    if (k == NodeKind::NK_CONTINUE) { return "CONTINUE"; }
    if (k == NodeKind::NK_EXPRSTMT) { return "EXPRSTMT"; }
    if (k == NodeKind::NK_BINOP) { return "BINOP"; }
    if (k == NodeKind::NK_UNARYOP) { return "UNARYOP"; }
    if (k == NodeKind::NK_CALL) { return "CALL"; }
    if (k == NodeKind::NK_IDENT) { return "IDENT"; }
    if (k == NodeKind::NK_NUMBER) { return "NUMBER"; }
    if (k == NodeKind::NK_STRING) { return "STRING"; }
    if (k == NodeKind::NK_FIELDACCESS) { return "FIELD"; }
    if (k == NodeKind::NK_STRUCT_DEF) { return "STRUCT"; }
    if (k == NodeKind::NK_FIELD_DEF) { return "FIELDDEF"; }
    if (k == NodeKind::NK_STRUCT_LIT) { return "STRUCTLIT"; }
    if (k == NodeKind::NK_FIELD_INIT) { return "FIELDINIT"; }
    if (k == NodeKind::NK_SWITCH) { return "SWITCH"; }
    if (k == NodeKind::NK_CASE) { return "CASE"; }
    if (k == NodeKind::NK_DEFAULT) { return "DEFAULT"; }
    if (k == NodeKind::NK_IMPL) { return "IMPL"; }
    if (k == NodeKind::NK_ENUM_DEF) { return "ENUM"; }
    if (k == NodeKind::NK_COMPOUND_ASSIGN) { return "CASSIGN"; }
    if (k == NodeKind::NK_PREFIX_INCDEC) { return "PREINC"; }
    if (k == NodeKind::NK_POSTFIX_INCDEC) { return "POSTINC"; }
    if (k == NodeKind::NK_LIST) { return "LIST"; }
    return "?";
}

func dump_ast(kinds string, svals string, ivals string,
              lefts string, rights string, extras string,
              id int, indent int) {
    if (id == -1) { return; }
    k := array_get(kinds, id);

    // LISTNODE: unwrap transparently (caller iterates via rights)
    if (k == NodeKind::NK_LIST) {
        l := array_get(lefts, id);
        if (l >= 0) { dump_ast(kinds, svals, ivals, lefts, rights, extras, l, indent); }
        return;
    }

    i := 0;
    while (i < indent) {
        print("  ");
        i = i + 1;
    }
    print(node_kind_name(k));
    sv := str_array_get(svals, id);
    if (str_len(sv) > 0) {
        print(" ");
        print(sv);
    }
    iv := array_get(ivals, id);
    if (iv != 0) {
        print(" [");
        print(int_to_str(iv));
        print("]");
    }
    println("");

    left := array_get(lefts, id);
    right := array_get(rights, id);
    extra := array_get(extras, id);

    // Nodes whose left is a list head
    if (k == NodeKind::NK_PROGRAM || k == NodeKind::NK_BLOCK || k == NodeKind::NK_STRUCT_DEF || k == NodeKind::NK_ENUM_DEF || k == NodeKind::NK_IMPL) {
        child := left;
        while (child != -1) {
            dump_ast(kinds, svals, ivals, lefts, rights, extras, child, indent + 1);
            child = array_get(rights, child);
        }
    }
    else if (k == NodeKind::NK_SWITCH) {
        // SWITCH: left=cond, right=cases list
        dump_ast(kinds, svals, ivals, lefts, rights, extras, left, indent + 1);
        child := right;
        while (child != -1) {
            dump_ast(kinds, svals, ivals, lefts, rights, extras, child, indent + 1);
            child = array_get(rights, child);
        }
    }
    else if (k == NodeKind::NK_FUNC) {
        // FUNC: left=params list, right=body
        child := left;
        while (child != -1) {
            dump_ast(kinds, svals, ivals, lefts, rights, extras, child, indent + 1);
            child = array_get(rights, child);
        }
        dump_ast(kinds, svals, ivals, lefts, rights, extras, right, indent + 1);
    }
    else if (k == NodeKind::NK_CALL) {
        // CALL: left=args list
        child := left;
        while (child != -1) {
            dump_ast(kinds, svals, ivals, lefts, rights, extras, child, indent + 1);
            child = array_get(rights, child);
        }
    }
    else if (k == NodeKind::NK_STRUCT_LIT) {
        // STRUCTLIT: left=field inits list
        child := left;
        while (child != -1) {
            dump_ast(kinds, svals, ivals, lefts, rights, extras, child, indent + 1);
            child = array_get(rights, child);
        }
    }
    else {
        dump_ast(kinds, svals, ivals, lefts, rights, extras, left, indent + 1);
        dump_ast(kinds, svals, ivals, lefts, rights, extras, right, indent + 1);
        dump_ast(kinds, svals, ivals, lefts, rights, extras, extra, indent + 1);
    }
}

// End of parser.pgl — entry point is in main.pgl
