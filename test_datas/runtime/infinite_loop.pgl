package main;
func main() {
    i := 0;
    for {
        if (i >= 5) { break; }
        println(i);
        i = i + 1;
    }
    println("done");

    // nested infinite loops
    x := 0;
    for {
        y := 0;
        for {
            if (y >= 3) { break; }
            y = y + 1;
        }
        x = x + 1;
        if (x >= 2) { break; }
    }
    println(x);
}
