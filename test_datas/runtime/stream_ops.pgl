package main;

func to_upper(ch int) int {
    if (ch >= 97 && ch <= 122) {
        return ch - 32;
    };
    return ch;
}

func main() {
    // Test >>: append char to string
    buf := "";
    72 >> buf;
    101 >> buf;
    108 >> buf;
    108 >> buf;
    111 >> buf;
    println(buf);

    // Test <>: in-place transform
    s := "hello";
    s <> to_upper;
    println(s);
}
