package main;

type Vec2 struct { x int; y int; }
type Rect struct { origin Vec2; size Vec2; }

func area(r Rect) int {
    return r.size.x * r.size.y;
}

func main() {
    r := Rect{
        origin: Vec2{x: 0, y: 0},
        size: Vec2{x: 10, y: 5}
    };
    println(area(r));
    r.size.x = 20;
    println(area(r));
    r.origin.x = 3;
    println(r.origin.x);
}
