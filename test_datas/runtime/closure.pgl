package main;

func apply(f func, x int) int {
    return f(x);
}

func make_adder(n int) func {
    return func(x) { return x + n; };
}

func main() {
    // Same-scope capture
    offset := 10;
    adder := func(x) { return x + offset; };
    println(apply(adder, 5));
    println(apply(adder, 15));

    // Cross-function closure
    add5 := make_adder(5);
    add10 := make_adder(10);
    println(apply(add5, 3));
    println(apply(add10, 3));

    // Multi-capture
    a := 100;
    b := 200;
    multi := func(x) { return x + a + b; };
    println(apply(multi, 5));
    return 0;
}
