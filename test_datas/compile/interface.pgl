package main;

type Shape interface {
    func area(self Shape) int;
    func get_name(self Shape) string;
}

type Rect struct {
    w int;
    h int;
}

type Circle struct {
    r int;
}

impl Rect Shape {
    func area(self Rect) int {
        return self.w * self.h;
    }
    func get_name(self Rect) string {
        return "rect";
    }
}

impl Circle Shape {
    func area(self Circle) int {
        return self.r * self.r * 3;
    }
    func get_name(self Circle) string {
        return "circle";
    }
}

func print_shape(s Shape) {
    println(s.get_name());
    println(s.area());
}

func main() {
    r := Rect{w: 3, h: 4};
    c := Circle{r: 5};
    s1 := Shape(r);
    s2 := Shape(c);
    print_shape(s1);
    print_shape(s2);
}
