package main;

func main() {
    arr := make_array(5);
    i := 0;
    for (i = 0; i < 5; ++i) {
        array_set(arr, i, i * i);
    }
    i = 0;
    for (i = 0; i < 5; ++i) {
        println(array_get(arr, i));
    }

    sa := make_str_array(3);
    str_array_set(sa, 0, "hello");
    str_array_set(sa, 1, "world");
    str_array_set(sa, 2, "!");
    println(str_array_get(sa, 0));
    println(str_array_get(sa, 1));
    println(str_array_get(sa, 2));
}
