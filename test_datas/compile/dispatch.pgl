package main;

func is_digit(c int) int {
    if (c >= 48 && c <= 57) { return 1; }
    return 0;
}

func is_alpha(c int) int {
    if ((c >= 65 && c <= 90) || (c >= 97 && c <= 122)) { return 1; }
    return 0;
}

func is_space(c int) int {
    if (c == 32 || c == 9 || c == 10) { return 1; }
    return 0;
}

func handle_digit(c int) int {
    print("DIGIT:");
    println(c);
    return 1;
}

func handle_alpha(c int) int {
    print("ALPHA:");
    println(c);
    return 2;
}

func handle_space(c int) int {
    print("SPACE:");
    println(c);
    return 3;
}

func main() int {
    // Test dispatch with function predicates
    // 'A' = 65 (alpha), '5' = 53 (digit), ' ' = 32 (space)
    c1 := 65;
    c1 >> [is_alpha -> handle_alpha, is_digit -> handle_digit, is_space -> handle_space];

    c2 := 53;
    c2 >> [is_alpha -> handle_alpha, is_digit -> handle_digit, is_space -> handle_space];

    c3 := 32;
    c3 >> [is_alpha -> handle_alpha, is_digit -> handle_digit, is_space -> handle_space];

    // Test with no match (should return 0)
    c4 := 33;
    result := 0;
    result = c4 >> [is_alpha -> handle_alpha, is_digit -> handle_digit];
    print("NO_MATCH:");
    println(result);

    return 0;
}
