package main;

func is_alpha(ch char) bool {
    if ((ch >= 'A') && (ch <= 'Z')) { return true; }
    if ((ch >= 'a') && (ch <= 'z')) { return true; }
    if (ch == '_') { return true; }
    return false;
}

func is_digit(ch char) bool {
    if ((ch >= '0') && (ch <= '9')) { return true; }
    return false;
}

func is_space(ch char) bool {
    if (ch == ' ') { return true; }
    if (ch == '\t') { return true; }
    if (ch == '\n') { return true; }
    if (ch == '\r') { return true; }
    return false;
}

func to_lower(ch char) char {
    if (ch >= 'A' && ch <= 'Z') {
        return ch + 32;
    }
    return ch;
}

func to_upper(ch char) char {
    if (ch >= 'a' && ch <= 'z') {
        return ch - 32;
    }
    return ch;
}

// ── 已实现的语法示例 ──

func show_transforms() {
    str := "HE11O";
    str <> to_lower;
    println(str);
    str <> to_upper;
    println(str);
}

// ── dispatch 语法示例：使用 >> [...] 进行模式匹配分发 ──

func handle_alpha(ch char) int { return 1; }
func handle_digit(ch char) int { return 2; }

func tokenize(input string) int {
    count := 0;
    buf := "";
    kind := 0;

    for ch in input {
        if (kind == 0) {
            if (is_space(ch)) { continue; }
            kind = ch >> [is_alpha -> handle_alpha, is_digit -> handle_digit];
            if (kind > 0) { ch >> buf; }
            continue;
        }

        stays := 0;
        if (kind == 1 && (is_alpha(ch) || is_digit(ch))) { stays = 1; }
        if (kind == 2 && is_digit(ch)) { stays = 1; }

        if (stays == 1) {
            ch >> buf;
        } else {
            if (kind == 1) { print("ID:"); }
            if (kind == 2) { print("NUM:"); }
            println(buf);
            count = count + 1;
            buf = "";
            kind = 0;

            if (!is_space(ch)) {
                kind = ch >> [is_alpha -> handle_alpha, is_digit -> handle_digit];
                if (kind > 0) { ch >> buf; }
            }
        }
    }
    if (kind > 0) {
        if (kind == 1) { print("ID:"); }
        if (kind == 2) { print("NUM:"); }
        println(buf);
        count = count + 1;
    }
    return count;
}

func main() int {
    show_transforms();
    count := tokenize("func main 42 hello123");
    print("Total: ");
    println(count);
    return 0;
}

